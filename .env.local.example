# Copy this file to .env.local and fill in your Supabase credentials
# Get these from: https://supabase.com → your project → Settings → API

NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# This key bypasses all security - ONLY used in server-side API routes, never in browser code
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Set this to your own email address so you become the admin
ADMIN_EMAIL=your-email@example.com
